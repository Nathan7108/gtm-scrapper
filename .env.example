PORT=3001

# Twitter scraping (@the-convocation/twitter-scraper)
# Leave blank for guest mode — account scraping works without login
# Add credentials to enable keyword search (optional)
TWITTER_USERNAME=
TWITTER_PASSWORD=

# LLM Provider: "claude-proxy" or "ollama"
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Claude Code Proxy (for Max subscription users)
CLAUDE_PROXY_URL=http://localhost:4171
CLAUDE_PROXY_KEY=local-dev

# Email digest (optional)
RESEND_API_KEY=
DIGEST_EMAIL=

# Supabase (optional — falls back to local JSON if not set)
SUPABASE_URL=
SUPABASE_ANON_KEY=
